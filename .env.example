# ============================================
# Avelon — Environment Variables
# ============================================

# --- Application ---
APP_ENV=development
APP_NAME=avelon
SECRET_KEY=change-me-to-a-secure-random-string
DEBUG=true

# --- Database ---
DATABASE_URL=postgresql+asyncpg://avelon_user:avelon_password@postgres:5432/avelon_db
DATABASE_URL_SYNC=postgresql://avelon_user:avelon_password@postgres:5432/avelon_db
POSTGRES_USER=avelon_user
POSTGRES_PASSWORD=avelon_password
POSTGRES_DB=avelon_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Legacy DB credentials fallback for existing non-fresh Postgres volumes
# (from pre-rebrand environments). Backend/worker migration startup will try
# these if the primary DATABASE_URL credentials fail.
LEGACY_POSTGRES_USER=aab_user
LEGACY_POSTGRES_PASSWORD=aab_password
LEGACY_POSTGRES_DB=aab_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT ---
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI Providers ---
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-xxxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-pro
CUSTOM_OPENAI_BASE_URL=
DEFAULT_AI_PROVIDER=openai

# --- Analyzer Runner ---
ANALYZER_RUNNER_URL=http://analyzer-runner:8001

# --- File Storage ---
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=1

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- CORS ---
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?
